# ========================================
# ADN SUMA GET - CONFIGURACIÓN DE ENTORNO
# ========================================
# Copiar este archivo como 'config.env' y configurar los valores

# ========================================
# CONFIGURACIÓN DE AUTENTICACIÓN
# ========================================
# Usuario del sistema de aduanas
NOMBRE_USUARIO=tu_usuario_aqui

# Contraseña del usuario
PASSWORD=tu_password_aqui

# URL base del sistema B-SSO
URL_B_SSO=https://suma.aduana.gob.bo/b-sso/rest

# URL base del sistema N-INGRESO
URL_N_INGRESO=https://suma.aduana.gob.bo/n-ingreso/api

# Tamaño de lista para paginación
SIZE_LIST=100

# ========================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ========================================
# Modo debug (true/false)
DEBUG=true

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Directorio donde se guardarán los archivos de salida
OUTPUT_DIR=output

# Nombre del archivo de credenciales
CREDENTIALS_FILE=credenciales.json

# Nombre del archivo de verificación
VERIFY_FILE=verificar.json

# ========================================
# CONFIGURACIÓN DE REQUESTS HTTP
# ========================================
# Timeout en segundos para peticiones HTTP
REQUEST_TIMEOUT=30

# Número máximo de reintentos en caso de error
MAX_RETRIES=3

# Delay entre reintentos en segundos
RETRY_DELAY=1

# ========================================
# HEADERS POR DEFECTO
# ========================================
# User-Agent para las peticiones HTTP
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/140.0.0.0 Safari/537.36

# Idioma preferido para las peticiones
ACCEPT_LANGUAGE=es-ES,es;q=0.9,en;q=0.8

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 1. NUNCA subir el archivo config.env al repositorio
# 2. Mantener las credenciales seguras
# 3. Verificar que la URL_B_SSO sea correcta para tu entorno
# 4. Ajustar el tamaño de lista según las necesidades
# 5. Configurar el nivel de logging apropiado para producción 